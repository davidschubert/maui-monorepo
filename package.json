{
  "name": "maui-monorepo",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:core": "pnpm --filter @maui/core dev",
    "dev:app": "pnpm --filter reddit-comments dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "changelog:draft": "node --env-file=apps/reddit-comments/.env packages/admin/scripts/changelog-draft.mjs",
    "migrate": "node --experimental-strip-types scripts/migrate.mjs",
    "create-site": "node --experimental-strip-types scripts/create-site.mjs",
    "check:manifests": "node --experimental-strip-types scripts/check-manifests.mjs"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "catalog:",
    "eslint": "catalog:"
  }
}
